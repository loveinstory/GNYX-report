    { "code": "angiotensin_i_4c", "name": "血管紧张素I 4℃", "short_name": "Ang I 4℃", "group": "raas", "source_names": ["血管紧张素I 4℃"], "unit": "ng/mL", "display_slot": "structured_report.tests only" },
    { "code": "angiotensin_ii", "name": "血管紧张素II", "short_name": "Ang II", "group": "raas", "source_names": ["血管紧张素II"], "unit": "pg/mL" },
    { "code": "angiotensin_ratio", "name": "血管紧张素II / I 比值", "short_name": "Ang II/Ang I", "group": "raas", "source_names": ["system_calculated"], "unit": "", "calculation": "Ang II(pg/mL) / Ang I(pg/mL)" },
    { "code": "renin", "name": "血浆肾素活性", "short_name": "Renin", "group": "raas", "source_names": ["血浆肾素活性"], "unit": "ng/mL/h" },
    { "code": "aldosterone_renin_ratio", "name": "血醛固酮/血浆肾素活性", "short_name": "ARR", "group": "raas", "source_names": ["血醛固酮／血浆肾素活性"], "unit": "", "display_slot": "structured_report.tests only" },
    { "code": "aldosterone", "name": "血醛固酮", "short_name": "Aldo", "group": "raas", "source_names": ["血醛固酮（ALD）"], "unit": "pg/mL" }
  ],
  "quality_gate": {
    "expected_source_test_count": 9,
    "expected_normalized_test_count": 10,
    "minimum_without_warning": 7,
    "required_report_codes": ["nt_probnp", "d_dimer", "ffa", "angiotensin_i", "angiotensin_ii", "angiotensin_ratio", "renin", "aldosterone"],
    "supplemental_source_codes": ["angiotensin_i_4c", "aldosterone_renin_ratio"],
